# ── Database ──────────────────────────────────────────────
DB_NAME=forked_nuces
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# ── Django ────────────────────────────────────────────────
# Generate a secure key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Frontend ──────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────
# Local dev: prints emails to console (no real email sent)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production Gmail SMTP (uncomment and set an App Password):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── CORS ──────────────────────────────────────────────────
# Add your frontend URL here
CORS_ALLOWED_ORIGINS=http://localhost:3000
